### Minimal .gitignore for this repo
### Goal: keep generated/big artifacts out, keep code/docs in.

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/

# --- Python ---
__pycache__/
*.py[cod]
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
ENV/
.python-version

# Local env files (secrets)
.env
.env.*

# --- Jupyter ---
.ipynb_checkpoints/

# --- Project-specific generated ---
attributes/

# --- Large / generated artifacts (don’t commit) ---
artifacts/
data/

# Experiment/training output directories (common defaults)
runs/
logs/
checkpoints/
wandb/
lightning_logs/
runs/

# Common model / tensor dump files (usually huge)
*.pt
*.pth
*.ckpt
*.safetensors
*.onnx
*.npy
*.npz
*.mmap
*.memmap
*.pkl
*.pickle
*.joblib

# --- Web ---
node_modules/
dist/
build/
.next/

# --- Misc ---
*.log
*.tmp
*.swp
*.swo
*.bak
